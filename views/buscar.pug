extends layout.pug
include mixins/publicacion.pug

block content
  h4.mb-4 🔍 Buscar

  .card.shadow-sm.mb-4
    .card-header.bg-white.fw-semibold 📷 Buscar publicaciones
    .card-body
      form(method="GET" action="/buscador")
        .row.g-2.align-items-end
          .col-md-3
            label.form-label.small.mb-1 Título o descripción
            input.form-control.form-control-sm(
              type="text" name="texto"
              placeholder="ej: atardecer en la montaña"
              value=query.texto
            )
          .col-md-3
            label.form-label.small.mb-1 Etiqueta
            input.form-control.form-control-sm(
              type="text" name="etiqueta"
              placeholder="ej: paisaje"
              value=query.etiqueta
            )
          .col-md-2
            label.form-label.small.mb-1 Desde
            input.form-control.form-control-sm(
              type="date" name="desde"
              value=query.desde
            )
          .col-md-2
            label.form-label.small.mb-1 Hasta
            input.form-control.form-control-sm(
              type="date" name="hasta"
              value=query.hasta
            )
          .col-md-2
            button.btn.btn-sm.btn-primary.w-100(type="submit") Buscar

  if query.texto || query.etiqueta
    if publicaciones.length === 0
      .alert.alert-secondary.mb-4 No se encontraron publicaciones.
    else
      p.text-muted.small.mb-2 #{publicaciones.length} resultado(s)
      .row.row-cols-2.row-cols-md-4.g-3.mb-5
        each pub in publicaciones
          +tarjetaPublicacion(pub)

  hr

  .card.shadow-sm.mb-4
    .card-header.bg-white.fw-semibold 👤 Buscar usuarios
    .card-body
      form(method="GET" action="/buscador")
        .row.g-2.align-items-end
          .col-md-10
            label.form-label.small.mb-1 Nombre de usuario
            input.form-control.form-control-sm(
              type="text" name="usuario"
              placeholder="ej: juan"
              value=query.usuario
            )
          .col-md-2
            button.btn.btn-sm.btn-primary.w-100(type="submit") Buscar

  if query.usuario
    if usuarios.length === 0
      .alert.alert-secondary No se encontraron usuarios.
    else
      p.text-muted.small.mb-2 #{usuarios.length} resultado(s)
      .row.row-cols-2.row-cols-md-4.g-3
        each u in usuarios
          .col
            a.card.h-100.shadow-sm.text-decoration-none.text-dark(
              href=`/perfil/${u.id}`
            )
              .card-body.text-center.p-3
                if u.foto_perfil
                  img.rounded-circle.mb-2(
                    src=u.foto_perfil width="50" height="50"
                    style="object-fit:cover;"
                  )
                else
                  .rounded-circle.bg-secondary.text-white.d-inline-flex.align-items-center.justify-content-center.mb-2(
                    style="width:50px;height:50px;font-size:20px;"
                  )= u.nombre_usuario[0].toUpperCase()
                p.fw-semibold.mb-0.small= "@" + u.nombre_usuario
                if u.descripcion
                  p.text-muted.small.mb-0= u.descripcion

  include mixins/modal.pug

block append content
  script.
    var publicaciones = !{JSON.stringify(publicaciones)};
    var usuarioId = !{JSON.stringify(usuarioId || null)};
  script(src="/js/publicaciones.js")