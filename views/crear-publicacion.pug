extends layout

block metadata
  title Nueva Publicacion
  link(rel="stylesheet", href="/css/crear-publicacion.css")

block content
  .container.py-4
    .row.justify-content-center
      .col-lg-8

        .d-flex.align-items-center.mb-4
          a.btn.btn-sm.btn-outline-secondary.me-3(href="/publicaciones") ← Volver
          h2.mb-0 Nueva Publicación

        if errores && errores.length > 0
          .alert.alert-danger
            ul.mb-0
              each error in errores
                li= error

        form(action="/publicaciones/crear" method="POST" id="formPublicacion")

          .card.shadow-sm.mb-4
            .card-header.bg-white.fw-semibold 📝 Información de la publicación
            .card-body

              .mb-3
                label.form-label.fw-medium(for="titulo") Título *
                input#titulo.form-control(
                  type="text"
                  name="titulo"
                  required
                  placeholder="Ej: Atardecer en las Sierras"
                  value=datos.titulo || ''
                )

              .mb-3
                label.form-label.fw-medium(for="descripcion") Descripción
                  span.text-muted.fw-normal  (opcional)
                textarea#descripcion.form-control(
                  name="descripcion"
                  rows="3"
                  placeholder="Contanos un poco más sobre la foto..."
                )= datos.descripcion || ''

              .mb-3
                label.form-label.fw-medium Etiquetas *
                  span.text-muted.fw-normal  (Enter o coma para agregar)
                .input-group
                  input#inputEtiqueta.form-control(
                    type="text"
                    placeholder="Ej: naturaleza, paisaje, argentina"
                    autocomplete="off"
                  )
                  button.btn.btn-outline-primary(type="button" onclick="agregarEtiqueta()") + Agregar
                div#contenedorTags.mt-2
                input#etiquetas(type="hidden" name="etiquetas" value=datos.etiquetas || '')
                .form-text Mínimo una etiqueta requerida.

          .card.shadow-sm.mb-4
            .card-header.bg-white.fw-semibold 🖼️ Imágenes
              span.text-muted.fw-normal.ms-2.fs-6 (podés subir varias)
            .card-body

              #zona-imagenes.d-flex.flex-column.align-items-center.justify-content-center.p-4.mb-3(
                onclick="document.getElementById('inputImagenes').click()"
              )
                p.mb-1.text-muted Hacé clic para seleccionar imágenes
                p.mb-0.text-muted.small o arrastrálas acá
                small.text-muted JPG, PNG, GIF, WEBP — máx 10MB por imagen

              input#inputImagenes(
                type="file"
                accept="image/*"
                multiple
                style="display:none"
              )

              #inputsBase64

              #previewGrid.row.g-3

          #panelImagenes

          .d-flex.gap-2.justify-content-end
            a.btn.btn-outline-secondary(href="/publicaciones") Cancelar
            button.btn.btn-primary(type="submit" id="btnPublicar") 📤 Publicar
  script(src="/js/crear-publicacion.js")