extends layout.pug

include mixins/publicacion.pug

block metadata
  title Mi Perfil - Fotaza

block content
  .container.py-4

    //Encabezado del perfil
    .card.mb-4.shadow-sm
      .card-body
        .row.align-items-center.g-3

          //Foto de perfil
          .col-auto
            if usuario.foto_perfil
              img.rounded-circle(
                src=usuario.foto_perfil
                width="100" height="100"
                style="object-fit:cover;"
              )
            else
              .rounded-circle.bg-secondary.d-flex.align-items-center.justify-content-center(
                style="width:100px;height:100px;"
              )
                span.text-white.fs-2= usuario.nombre_usuario[0].toUpperCase()

          //Datos
          .col
            h3.fw-bold.mb-0= usuario.nombre_usuario
            p.text-muted.mb-2= usuario.descripcion || "Sin descripción todavía."
            button.btn.btn-sm.btn-outline-primary(
              data-bs-toggle="collapse"
              data-bs-target="#formEditarPerfil"
            ) ✏️ Editar perfil

          //Form editar (colapsable)
          .col-12
            #formEditarPerfil.collapse
              hr
              form(action="/perfil/actualizar" method="POST")
                .mb-2
                  label.form-label.small Descripción
                  textarea.form-control.form-control-sm(
                    name="descripcion"
                    rows="2"
                    placeholder="Contá algo sobre vos..."
                  )= usuario.descripcion || ""
                .mb-2
                  label.form-label.small Foto de perfil
                  .d-flex.align-items-center.gap-3.mt-1
                    //Preview
                    #previewFotoPerfil
                      if usuario.foto_perfil
                        img.rounded-circle(
                          src=usuario.foto_perfil
                          width="60" height="60"
                          style="object-fit:cover;"
                        )
                      else
                        .rounded-circle.bg-secondary.d-flex.align-items-center.justify-content-center(
                          style="width:60px;height:60px;"
                        )
                          span.text-white= usuario.nombre_usuario[0].toUpperCase()
                    div
                      button.btn.btn-sm.btn-outline-secondary(
                        type="button"
                        onclick="document.getElementById('inputFotoPerfil').click()"
                      ) 📁 Elegir foto
                      input#inputFotoPerfil(
                        type="file"
                        accept="image/*"
                        style="display:none"
                      )
                      input#inputFotoPerfilBase64(
                        type="hidden"
                        name="foto_perfil"
                      )
                button.btn.btn-sm.btn-primary(type="submit") Guardar

    //Publicaciones
    h5.fw-bold.mb-3 Mis publicaciones (#{publicaciones.length})

    if publicaciones.length === 0
      .alert.alert-info No publicaste nada todavía.
    else
      .row
        each pub in publicaciones
          +tarjetaPublicacion(pub)

  //Modal reutilizado
  #modalPublicacion.modal.fade(tabindex="-1" aria-hidden="true")
    .modal-dialog.modal-xl.modal-dialog-centered
      .modal-content
        .modal-body.p-0
          .row.g-0
            .col-md-7.bg-dark.d-flex.align-items-center.justify-content-center(
              style="min-height: 480px; position: relative;"
            )
              #carruselPublicacion.carousel.slide.w-100(data-bs-interval="false")
                .carousel-indicators#indicadoresCarrusel
                .carousel-inner#contenedorFotos
                button.carousel-control-prev(type="button" data-bs-target="#carruselPublicacion" data-bs-slide="prev")
                  span.carousel-control-prev-icon
                button.carousel-control-next(type="button" data-bs-target="#carruselPublicacion" data-bs-slide="next")
                  span.carousel-control-next-icon
              #contadorImagenes.position-absolute.bottom-0.start-50.translate-middle-x.mb-2
                span.badge.bg-dark.bg-opacity-75

            .col-md-5.d-flex.flex-column.bg-white(style="max-height: 480px;")
              .d-flex.justify-content-between.align-items-center.border-bottom.p-3
                div
                  h5#modalTitulo.fw-bold.mb-0 —
                  small#modalAutor.text-muted —
                button.btn-close(data-bs-dismiss="modal" aria-label="Cerrar")

              .flex-grow-1.overflow-auto.p-3(style="min-height: 0;")
                .d-flex.align-items-center.gap-2.mb-3
                  span#promedioEstrellas.fs-5
                  span#textoPromedio.text-muted.small

                h6.fw-bold.small.text-secondary Comentarios
                #listaComentarios.mb-2
                  p.text-muted.small.text-center.pt-1 No hay comentarios aún.

              .border-top.p-2
                #seccionComentar
                  .input-group.input-group-sm
                    input#inputComentario.form-control(type="text" placeholder="Escribí un comentario...")
                    button#btnComentar.btn.btn-primary Publicar

                #mensajeComentariosCerrados.d-none
                  p.text-muted.small.text-center.mb-0 💬 Los comentarios están cerrados.

                #btnToggleComentariosWrap.d-none.mt-1
                  button#btnToggleComentarios.btn.btn-sm.btn-outline-secondary.w-100(type="button")

                .d-flex.gap-2.mt-2
                  button#btnDenuncia.btn.btn-sm.btn-outline-danger(type="button") 🚨 Denunciar
                  button#btnMeInteresa.btn.btn-sm.btn-outline-success(type="button") 💛 Me interesa

  script.
    var publicaciones = !{JSON.stringify(publicaciones)};
    var usuarioId     = !{JSON.stringify(usuarioId)};
  script(src="/js/publicaciones.js")
  script(src="/js/perfil.js")