extends layout.pug

include mixins/publicacion.pug

block metadata
  title Mi Perfil - Fotaza

block content
  .container.py-4

    //Encabezado del perfil
    .card.mb-4.shadow-sm
      .card-body
        .row.align-items-center.g-3

          //Foto de perfil
          .col-auto
            if usuario.foto_perfil
              img.rounded-circle(
                src=usuario.foto_perfil
                width="100" height="100"
                style="object-fit:cover;"
              )
            else
              .rounded-circle.bg-secondary.d-flex.align-items-center.justify-content-center(
                style="width:100px;height:100px;"
              )
                span.text-white.fs-2= usuario.nombre_usuario[0].toUpperCase()

          //Datos
          .col
            h3.fw-bold.mb-0= usuario.nombre_usuario
            p.text-muted.mb-2= usuario.descripcion || "Sin descripción todavía."

            //Contadores seguidores/seguidos
            .d-flex.gap-3.mb-2
              span.small
                strong= cantPublicaciones
                |  publicaciones
              span.small
                strong= cantSeguidores
                |  seguidores
              span.small
                strong= cantSeguidos
                |  siguiendo

            //Botón seguir (solo en perfil ajeno)
            if !miPerfil
              if yaLoSigo
                button.btn.btn-sm.btn-secondary#btnDejarDeSeguir(
                  data-id=usuario.id
                ) ✓ Seguido
              else
                button.btn.btn-sm.btn-primary#btnSeguir(
                  data-id=usuario.id
                ) + Seguir

            if miPerfil
              button.btn.btn-sm.btn-outline-primary(
                data-bs-toggle="collapse"
                data-bs-target="#formEditarPerfil"
              ) ✏️ Editar perfil

          //Form editar (colapsable)
          .col-12
            if miPerfil
              #formEditarPerfil.collapse
                hr
                form(action="/perfil/actualizar" method="POST")
                  .mb-2
                    label.form-label.small Descripción
                    textarea.form-control.form-control-sm(
                      name="descripcion"
                      rows="2"
                      placeholder="Contá algo sobre vos..."
                    )= usuario.descripcion || ""
                  .mb-2
                    label.form-label.small Foto de perfil
                    .d-flex.align-items-center.gap-3.mt-1
                      //Preview
                      #previewFotoPerfil
                        if usuario.foto_perfil
                          img.rounded-circle(
                            src=usuario.foto_perfil
                            width="60" height="60"
                            style="object-fit:cover;"
                          )
                        else
                          .rounded-circle.bg-secondary.d-flex.align-items-center.justify-content-center(
                            style="width:60px;height:60px;"
                          )
                            span.text-white= usuario.nombre_usuario[0].toUpperCase()
                      div
                        button.btn.btn-sm.btn-outline-secondary(
                          type="button"
                          onclick="document.getElementById('inputFotoPerfil').click()"
                        ) 📁 Elegir foto
                        input#inputFotoPerfil(
                          type="file"
                          accept="image/*"
                          style="display:none"
                        )
                        input#inputFotoPerfilBase64(
                          type="hidden"
                          name="foto_perfil"
                        )
                  button.btn.btn-sm.btn-primary(type="submit") Guardar

    //Publicaciones
    h5.fw-bold.mb-3 Mis publicaciones (#{publicaciones.length})

    if publicaciones.length === 0
      .alert.alert-info No publicaste nada todavía.
    else
      .row
        each pub in publicaciones
          +tarjetaPublicacion(pub)

  include mixins/modal.pug

  script.
    var publicaciones = !{JSON.stringify(publicaciones)};
    var usuarioId     = !{JSON.stringify(usuarioId)};

  script(src="/js/publicaciones.js")
  script(src="/js/perfil.js")