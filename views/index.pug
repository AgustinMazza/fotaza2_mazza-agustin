extends layout.pug

include mixins/publicacion.pug

block metadata
  title Inicio - Fotaza

block content
  .text-center.py-4.mb-4
    h1.fw-bold.display-6 📷 Bienvenido a Fotaza
    p.text-muted.lead Explorá fotografías compartidas por nuestra comunidad
    p.text-muted.lead Si queres ver Todas las publicaciones Registrate y empeza a Compartir!

  if publicaciones.length === 0
    .alert.alert-info.text-center No hay publicaciones públicas para mostrar todavía.
  else
    .row
      each pub in publicaciones
        +tarjetaPublicacion(pub)

  #modalPublicacion.modal.fade(tabindex="-1" aria-hidden="true")
    .modal-dialog.modal-xl.modal-dialog-centered
      .modal-content
        .modal-body.p-0
          .row.g-0

            .col-md-7.bg-dark.d-flex.align-items-center.justify-content-center(
              style="min-height: 480px; position: relative;"
            )
              #carruselPublicacion.carousel.slide.w-100(data-bs-interval="false")
                .carousel-indicators#indicadoresCarrusel
                .carousel-inner#contenedorFotos
                button.carousel-control-prev(
                  type="button"
                  data-bs-target="#carruselPublicacion"
                  data-bs-slide="prev"
                )
                  span.carousel-control-prev-icon(aria-hidden="true")
                button.carousel-control-next(
                  type="button"
                  data-bs-target="#carruselPublicacion"
                  data-bs-slide="next"
                )
                  span.carousel-control-next-icon(aria-hidden="true")
              #contadorImagenes.position-absolute.bottom-0.start-50.translate-middle-x.mb-2
                span.badge.bg-dark.bg-opacity-75

            .col-md-5.d-flex.flex-column.bg-white(style="max-height: 480px;")
              .d-flex.justify-content-between.align-items-center.border-bottom.p-3
                div
                  h5#modalTitulo.fw-bold.mb-0 —
                  small#modalAutor.text-muted —
                button.btn-close(data-bs-dismiss="modal" aria-label="Cerrar")

              .flex-grow-1.overflow-auto.p-3(style="min-height: 0;")
                .d-flex.align-items-center.gap-2.mb-3
                  span#promedioEstrellas.fs-5
                  span#textoPromedio.text-muted.small

                if usuarioId
                  .mb-3.p-2.bg-light.rounded
                    p.small.text-muted.mb-1 Tu valoración:
                    #estrellasContenedor.fs-4(style="cursor:pointer;")
                      each val in [1,2,3,4,5]
                        span.estrella-voto.text-muted(data-valor=val) ★
                else
                  .mb-3.p-2.bg-light.rounded
                    p.small.text-muted.mb-0.text-center
                      a(href="/login") Iniciá sesión
                      |  para votar y comentar.

                h6.fw-bold.small.text-secondary Comentarios
                #listaComentarios.mb-2
                  p.text-muted.small.text-center.pt-1 No hay comentarios aún.

              .border-top.p-2
                if usuarioId
                  #seccionComentar
                    .input-group.input-group-sm
                      input#inputComentario.form-control(
                        type="text"
                        placeholder="Escribí un comentario..."
                      )
                      button#btnComentar.btn.btn-primary Publicar

                  #mensajeComentariosCerrados.d-none
                    p.text-muted.small.text-center.mb-0 💬 Los comentarios están cerrados.

                  #btnToggleComentariosWrap.d-none.mt-1
                    button#btnToggleComentarios.btn.btn-sm.btn-outline-secondary.w-100(type="button")

                  .d-flex.gap-2.mt-2
                    div
                      button#btnDenuncia.btn.btn-sm.btn-outline-danger(type="button") 🚨 Denunciar
                      #formDenunciaWrap.d-none.mt-2.p-2.border.rounded.bg-light(style="font-size:13px;")
                        select#selectMotivo.form-select.form-select-sm.mb-1
                          option(value="") — Seleccioná un motivo —
                          option(value="contenido_inapropiado") Contenido inapropiado
                          option(value="derechos_de_autor") Derechos de autor
                          option(value="spam") Spam
                          option(value="violencia") Violencia
                          option(value="otro") Otro
                        textarea#textaDenuncia.form-control.form-control-sm.mb-1(
                          rows="2"
                          placeholder="Descripción (opcional)"
                        )
                        button#btnEnviarDenuncia.btn.btn-sm.btn-danger.w-100 Enviar denuncia
                    button#btnMeInteresa.btn.btn-sm.btn-outline-success(type="button") 💛 Me interesa

                  #panelMeInteresa.d-none.border-top.p-2.bg-light
                    p.small.fw-bold.mb-1 ¡Interés registrado! El autor fue notificado.
                    p#datosMeInteresa.small.text-muted.mb-0

  script.
    var publicaciones = !{JSON.stringify(publicaciones)};
    var usuarioId     = !{JSON.stringify(usuarioId)};
  script(src="/js/publicaciones.js")