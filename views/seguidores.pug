extends layout.pug

block metadata
  title #{titulo} - Fotaza

block content
  .container.py-4
    h5.fw-bold.mb-3= titulo

    if usuarios.length === 0
      .alert.alert-info No hay usuarios para mostrar.
    else
      .row
        each u in usuarios
          .col-sm-6.col-md-4.col-lg-3.mb-3
            .card.shadow-sm
              .card-body.d-flex.align-items-center.gap-3
                if u.foto_perfil
                  img.rounded-circle(
                    src=u.foto_perfil
                    width="50" height="50"
                    style="object-fit:cover;"
                  )
                else
                  .rounded-circle.bg-secondary.d-flex.align-items-center.justify-content-center(
                    style="width:50px;height:50px;flex-shrink:0;"
                  )
                    span.text-white= u.nombre_usuario[0].toUpperCase()
                a(href='/perfil/' + u.id).fw-bold.text-decoration-none= u.nombre_usuario